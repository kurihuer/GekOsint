# ============================================================
# GekOsint v6.0 — Variables de Entorno
# Copia este archivo como .env y rellena los valores
# ============================================================

# ── OBLIGATORIO ─────────────────────────────────────────────
# Token del bot — obténlo en https://t.me/BotFather
GEKOSINT_TOKEN=tu_token_de_botfather_aqui

# ID Telegram del administrador principal
# Obtén tu ID enviando /start a @userinfobot
ADMIN_ID=0

# ── CONTROL DE ACCESO ────────────────────────────────────────
# IDs adicionales autorizados, separados por comas
# Si está vacío, solo ADMIN_ID tiene acceso
GEKOSINT_ALLOWED=

# ── RATE LIMITING ────────────────────────────────────────────
# Segundos de cooldown entre consultas por usuario (default: 5)
RATE_LIMIT_SECONDS=5
# Número de consultas rápidas antes de aplicar cooldown (default: 3)
RATE_LIMIT_BURST=3

# ── LOGGING ──────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── DEPLOY / HOSTING ─────────────────────────────────────────
# URL pública del bot (Railway, Render, Koyeb, etc.)
PUBLIC_URL=

# URL para webhook (si usas modo webhook en lugar de polling)
WEBHOOK_URL=

# Puerto del servidor de archivos local (default: 8000)
FILE_SERVER_PORT=8000

# ── APIs EXTERNAS — OPCIONALES ────────────────────────────────
# Cada una mejora un módulo específico.
# El bot funciona sin ellas, pero con menos datos.

# GitHub Token — necesario para Geo/Cam Tracker (crear Gist)
# Scope mínimo: gist
GITHUB_TOKEN=

# Vercel Token — hosting alternativo de tracking pages
VERCEL_TOKEN=

# RapidAPI Key — Truecaller caller-ID (Phone Intel)
# https://rapidapi.com/truecaller-truecaller-default/api/truecaller-api3
RAPIDAPI_KEY=

# Numverify — validación de números de teléfono
# https://numverify.com
NUMVERIFY_KEY=

# Hunter.io — verificación de emails
# https://hunter.io
HUNTER_KEY=

# Shodan — puertos y servicios expuestos
# https://shodan.io
SHODAN_API_KEY=

# GreyNoise — clasificación de IPs (ruido vs. actores maliciosos)
# https://greynoise.io
GREYNOISE_API_KEY=

# AbuseIPDB — reportes de abuso de IPs
# https://abuseipdb.com
ABUSEIPDB_KEY=

# VirusTotal — reputación de IPs y URLs
# https://virustotal.com
VT_API_KEY=

# IPStack — geolocalización de IPs
# https://ipstack.com
IPSTACK_KEY=

# Netlify Token — hosting de tracking pages (deployer recomendado)
# https://app.netlify.com/user/applications#personal-access-tokens
# Da URLs *.netlify.app directas, sin página intermedia.
NETLIFY_TOKEN=

# ── IG OSINT — Cookies de sesión Instagram ──────────────────
# Cómo conseguirlas (UNA VEZ, en compu de confianza):
#   1. Logueate en instagram.com con la cuenta DEDICADA (no la personal).
#   2. F12 → Application → Cookies → https://www.instagram.com
#   3. Copiá los valores de las cookies abajo.
# Renová cuando IG OSINT empiece a fallar con 401/checkpoint.
IG_USERNAME=
IG_SESSIONID=
IG_DS_USER_ID=
IG_CSRFTOKEN=

# ── Gmail / Google OSINT (cookies de sesión, OPCIONAL) ──────
# Sin cookies funciona con recovery hints + Gravatar.
# Para People API (más datos), conseguí las cookies así:
#   F12 en accounts.google.com (logueado con cuenta dedicada)
#   → Application → Cookies → google.com → copiar valores.
GOOGLE_SAPISID=
GOOGLE_HSID=
GOOGLE_SSID=
GOOGLE_APISID=
GOOGLE_SECURE_1PSID=
GOOGLE_SECURE_3PSID=
GOOGLE_NID=

# ── Facebook OSINT (cookies de sesión, OPCIONAL) ────────────
# Sin cookies funciona con recovery hints + findmyfbid + foto.
# Para más datos de Pages: F12 en facebook.com (cuenta dedicada)
#   → Application → Cookies → facebook.com → copiar valores.
FB_C_USER=
FB_XS=
FB_DATR=
FB_FR=
