# ============================================
# GekOsint v4.0 - Variables de Entorno
# ============================================

# Token del Bot de Telegram (OBLIGATORIO)
# Obtén uno en: https://t.me/BotFather
GEKOSINT_TOKEN=tu_token_de_botfather_aqui

# Nivel de logging (INFO, DEBUG, WARNING, ERROR)
LOG_LEVEL=INFO

# ============================================
# APIs Externas (OPCIONALES)
# ============================================

# GitHub Token (NECESARIO para Geo/Cam Tracker - crear Gist privado)
# Scope: gist
GITHUB_TOKEN=

# Vercel Token (para hosting de tracking pages)
VERCEL_TOKEN=

# RapidAPI Key (Truecaller)
RAPIDAPI_KEY=

# Shodan (puertos y servicios expuestos en IP)
SHODAN_API_KEY=

# GreyNoise (clasificación de ruido)
GREYNOISE_API_KEY=

# AbuseIPDB (reportes de abuso)
ABUSEIPDB_KEY=

# VirusTotal (reputación IP)
VT_API_KEY=

# Numverify (validación telefónica)
NUMVERIFY_KEY=

# ============================================
# Control de Acceso (OPCIONAL)
# ============================================
ALLOWED_USERS=
